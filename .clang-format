BasedOnStyle: LLVM   # Or Google, Microsoft, etc. — change as you like

# === Spaces BEFORE opening parentheses ===
SpaceBeforeParens: Custom
SpaceBeforeParensOptions:
  AfterControlStatements: true          # if ( cond ), while ( cond ), for ( ... )
  AfterForeachMacros: true
  AfterFunctionDeclarationName: false   # void func(int x)  ← no space
  AfterFunctionDefinitionName: false    # void func(int x) { ... } ← no space
  AfterIfMacros: true
  BeforeNonEmptyParentheses: false      # This is the key: no space before ( when there ARE arguments
  # Most other options default to false (tight for calls/decls)

# === Spaces INSIDE parentheses () ===
SpacesInParens: Custom
SpacesInParensOptions:
  InEmptyParentheses: false             # No space in empty: func()
  InConditionalStatements: true         # Space in if/while/for when non-empty: if ( cond )
  InCStyleCasts: false                  # (int)x  or  ( int )x — your choice
  Other: true                           # Space inside function calls when parameters present: func( arg )

# === Square brackets [] ===
SpacesInSquareBrackets: true            # arr[ index ] when content, but empty [] stays tight in most cases

# === Braces {} ===
SpacesInBraces: true                    # { 1, 2, 3 } when values
SpaceInEmptyBraces: Never               # {} stays tight (newer versions support this)
# Or for more control (if your version has it):
# SpaceInEmptyBraces: Custom
# SpaceInEmptyBracesOptions:
#   Block: false   # for function bodies etc.

# Helpful extras
SpaceBeforeAssignmentOperators: true
SpaceBeforeRangeBasedForLoopColon: true
