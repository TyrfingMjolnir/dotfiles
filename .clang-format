# Base style (change to LLVM, Google, etc. as needed, or remove for fully custom)
BasedOnStyle: LLVM

# === Parentheses () ===
SpacesInParens: Custom
SpacesInParensOptions:
  InEmptyParentheses: false   # No space in empty: foo()
  InConditionalStatements: true   # Space inside if/while/for/etc. when non-empty: if (cond)
  InCStyleCasts: true             # Optional: space in (int) x  → ( int ) x
  Other: true                     # Space inside function calls/decls when non-empty: foo(bar)
  ExceptDoubleParentheses: false  # Optional tweak for (( ))

# === Square Brackets [] ===
SpacesInSquareBrackets: true      # Spaces when content present: arr[ i ]
# Note: No built-in "empty vs non-empty" toggle for [], so this applies to both.
# Empty [] will get spaces ( [ ] ) if true; tight [] if false.

# === Braces {} ===
SpacesInBraces: true              # Spaces when content present in braced lists/initializers: { a, b }
SpaceInEmptyBraces: Never         # Or use Custom if available in your version (see below)
# For blocks like void f() {}, empty often stays tight regardless.

# Additional helpful options
SpaceBeforeParens: NonEmptyParentheses   # Space before ( only if non-empty, e.g. f (arg) but f()
# Or use Custom for more control if needed.
